generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  name             String
  cedula           String?   @unique
  role             Role      @default(ADMIN)
  activo           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  ingresosCreados  Ingreso[] @relation("IngresosCreados")
  abonosCreados    Abono[]   @relation("AbonosCreados")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  VENTAS
  PRODUCCION
  SOLO_LECTURA
}

model Client {
  id             String       @id @default(cuid())
  name           String
  business       String
  contact        String?
  whatsapp       String?
  email          String?
  status         ClientStatus @default(ACTIVE)
  notes          String?
  servicePlanId  String?
  servicePlan    ServicePlan? @relation(fields: [servicePlanId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  monthlyPlans   MonthlyPlan[]
  contents       Content[]
  ingresos       Ingreso[]
}

enum ServicePlanType {
  CONTENIDO
  IA
  FOTOGRAFIA
  PERSONALIZADO
}

model ServicePlan {
  id                String          @id @default(cuid())
  nombre            String
  tipo              ServicePlanType
  precio            Float
  cantidadReels              Int             @default(0)
  cantidadVideosHorizontales Int             @default(0)
  cantidadFotos              Int             @default(0)
  cantidadImagenesFlyers     Int             @default(0)
  jornadasGrabacion          Int             @default(0)
  duracion                   String?
  vestuarios                 Int             @default(0)
  descripcion       String?
  caracteristicas   String[]
  esDefault         Boolean         @default(false)
  activo            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  clients           Client[]
}

enum ClientStatus {
  ACTIVE
  PAUSED
  FINISHED
}

model MonthlyPlan {
  id             String        @id @default(cuid())
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month          Int
  year           Int
  reelsCount     Int           @default(0)
  carouselsCount Int           @default(0)
  flyersCount    Int           @default(0)
  monthlyPrice   Float         @default(0)
  paymentStatus  PaymentStatus @default(PENDING)
  planStatus     PlanStatus    @default(IN_PROGRESS)
  observations   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  contents       Content[]
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum PlanStatus {
  IN_PROGRESS
  COMPLETED
  DELAYED
}

model Content {
  id            String        @id @default(cuid())
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planId        String?
  plan          MonthlyPlan?  @relation(fields: [planId], references: [id], onDelete: SetNull)
  type          ContentType
  title         String
  status        ContentStatus @default(PENDING)
  driveLink     String?
  publishedLink String?
  publishedAt   DateTime?
  views         Int           @default(0)
  likes         Int           @default(0)
  comments      Int           @default(0)
  shares        Int           @default(0)
  saves         Int           @default(0)
  observations  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum ContentType {
  REEL
  CAROUSEL
  FLYER
  VIDEO_HORIZONTAL
  FOTO
  IMAGEN_FLYER
  EXTRA
}

enum ContentStatus {
  PENDING
  EDITING
  APPROVED
  PUBLISHED
  COMPLETED
  PENDIENTE
  EN_PROCESO
  ENTREGADO
  PUBLICADO
}

enum TipoServicio {
  FOTOGRAFIA
  REELS
  VIDEOS_HORIZONTALES
  IMAGENES_FLYERS
  PLAN_MENSUAL
  PERSONALIZADO
}

enum EstadoPago {
  PAGADO
  PENDIENTE
  PARCIAL
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  DEPOSITO
  TARJETA
  OTRO
}

model Ingreso {
  id            String       @id @default(cuid())
  clienteId     String?
  cliente       Client?      @relation(fields: [clienteId], references: [id])
  tipoServicio  TipoServicio
  descripcion   String?
  monto         Float
  montoPagado   Float        @default(0)
  estadoPago    EstadoPago   @default(PENDIENTE)
  metodoPago    MetodoPago?
  fechaIngreso  DateTime     @default(now())
  observaciones String?
  creadoPor     String
  creadoPorUser User         @relation("IngresosCreados", fields: [creadoPor], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  abonos        Abono[]
}

model Abono {
  id            String      @id @default(cuid())
  ingresoId     String
  ingreso       Ingreso     @relation(fields: [ingresoId], references: [id], onDelete: Cascade)
  monto         Float
  metodoPago    MetodoPago?
  fechaAbono    DateTime    @default(now())
  observacion   String?
  creadoPor     String
  creadoPorUser User        @relation("AbonosCreados", fields: [creadoPor], references: [id])
  createdAt     DateTime    @default(now())
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}
